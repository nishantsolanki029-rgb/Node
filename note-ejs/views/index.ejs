<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Task Manager</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-gray-300">
    <section>
        <!-- task form -->
        <h1 class="text-center text-5xl font-semibold my-5">Task Files Generator</h1>
        <div class="flex items-center justify-center">
            <form action="/create" method="post">
                <input type="text" name="title" id="" class="bg-gray-400 text-2xl rounded-xl block mb-2 px-3 py-2"
                    placeholder="Title...">
                <input type="text" name="details" id="" class="bg-gray-400 text-2xl rounded-xl block mb-2 px-3 py-2"
                    placeholder="Details...">
                <input type="submit" value="Add Task"
                    class="bg-black text-white w-full rounded-xl px-4 py-2 active:scale-95 active:bg-black/30 active:bg-gray-600 transition duration-300 font-semibold">
            </form>
        </div>

        <!-- tasks -->
        <div class="flex justify-center flex-wrap gap-4 p-10 mt-10 ">

             <% data.forEach((val)=>{    %>
                     <div class="bg-black text-white p-2 w-1/4 rounded-xl h-32 flex flex-col justify-between">
                    <h1 class="text-4xl text-center"><%= val %></h1>
                    <div class="flex justify-between">
                        <a class="text-blue-400 actuve:text-red-400" href="/open/<%= val %>">Open</a>
                        <a  class="text-grey-700 actuve:text-white" href="/edit/<%= val %>">Edit File</a>
                    </div>
                </div>
            <% }) %>

           
        </div>
    </section>
</body>

</html>