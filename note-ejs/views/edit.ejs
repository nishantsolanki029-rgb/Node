<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Files</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-gray-300">
    <section class="my-10">

        <!-- task form -->
        <div class="flex items-center justify-center">
            <form action="/rename" method="post">
                <input type="Old File Name" name="old" id="" class="bg-gray-400 text-2xl rounded-xl block mb-2 px-3 py-2"
                    placeholder="Title..." value="<%= oldname %>" readonly>
                <input type="New File Name" name="new" id="" class="bg-gray-400 text-2xl rounded-xl block mb-2 px-3 py-2"
                    placeholder="Details...">
                <input type="submit" value="Rename File"
                    class="bg-orange-600 text-white w-full rounded-xl px-4 py-2 active:scale-95 active:bg-black/30 active:bg-orange-200 transition duration-300 font-semibold">
            </form>
        </div>

    </section>
</body>

</html>